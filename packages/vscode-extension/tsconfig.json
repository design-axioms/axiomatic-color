{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "verbatimModuleSyntax": false,
    "rewriteRelativeImportExtensions": false,
    "allowImportingTsExtensions": false,
    "types": ["vscode", "node"]
  },
  "references": [{ "path": "../core" }],
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
