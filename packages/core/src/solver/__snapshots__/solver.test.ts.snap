/* Forced colors — cede to OS palette per surface role */
@media (forced-colors: active) {
  .surface-page {
    --axm-surface: Canvas;
    --axm-text-high: CanvasText;
    --axm-text-strong: CanvasText;
    --axm-text-subtle: CanvasText;
    --axm-text-subtlest: CanvasText;
    --axm-text-link: LinkText;
    --axm-text-disabled: GrayText;
    --axm-border-decorative: CanvasText;
    --axm-border-interactive: CanvasText;
    --axm-border-critical: CanvasText;
  }
  .surface-workspace {
    --axm-surface: Canvas;
    --axm-text-high: CanvasText;
    --axm-text-strong: CanvasText;
    --axm-text-subtle: CanvasText;
    --axm-text-subtlest: CanvasText;
    --axm-text-link: LinkText;
    --axm-text-disabled: GrayText;
    --axm-border-decorative: CanvasText;
    --axm-border-interactive: CanvasText;
    --axm-border-critical: CanvasText;
  }
  .surface-card {
    --axm-surface: Canvas;
    --axm-text-high: CanvasText;
    --axm-text-strong: CanvasText;
    --axm-text-subtle: CanvasText;
    --axm-text-subtlest: CanvasText;
    --axm-text-link: LinkText;
    --axm-text-disabled: GrayText;
    --axm-border-decorative: CanvasText;
    --axm-border-interactive: CanvasText;
    --axm-border-critical: CanvasText;
  }
  .surface-action {
    --axm-surface: ButtonFace;
    --axm-text-high: ButtonText;
    --axm-text-strong: ButtonText;
    --axm-text-subtle: ButtonText;
    --axm-text-subtlest: ButtonText;
    --axm-text-link: LinkText;
    --axm-text-disabled: GrayText;
    --axm-border-decorative: CanvasText;
    --axm-border-interactive: ButtonBorder;
    --axm-border-critical: CanvasText;
  }
  .surface-spotlight {
    --axm-surface: Canvas;
    --axm-text-high: CanvasText;
    --axm-text-strong: CanvasText;
    --axm-text-subtle: CanvasText;
    --axm-text-subtlest: CanvasText;
    --axm-text-link: LinkText;
    --axm-text-disabled: GrayText;
    --axm-border-decorative: CanvasText;
