// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`solver (rich config) > CSS output matches golden master for rich config 1`] = `
"/* Root — color-scheme drives light-dark() */
:root {
  color-scheme: light;
  --axm-hue: 0;
  --axm-chroma: 0;
}

/* Hue/chroma properties — inheriting */
@property --axm-hue {
  syntax: "<number>";
  inherits: true;
  initial-value: 0;
}

@property --axm-chroma {
  syntax: "<number>";
  inherits: true;
  initial-value: 0;
}

/* Engine — computation layer */
/* Surface paint: oklch(lightness, tapered-chroma, hue) */
/* Taper: min(chroma, chroma × (1 - |2L - 1|)) — §5 safe bicone */
/* Text: inherits from nearest surface context */

/* Surface classes */

.surface-page {
  --axm-surface: light-dark(oklch(0.9750 calc(var(--axm-chroma) * (1 - abs(2 * 0.9750 - 1))) var(--axm-hue)), oklch(0.2500 calc(var(--axm-chroma) * (1 - abs(2 * 0.2500 - 1))) var(--axm-hue)));
  --axm-text-high: light-dark(oklch(0.2024 calc(var(--axm-chroma) * (1 - abs(2 * 0.2024 - 1))) var(--axm-hue)), oklch(0.9746 calc(var(--axm-chroma) * (1 - abs(2 * 0.9746 - 1))) var(--axm-hue)));
  --axm-text-strong: light-dark(oklch(0.3072 calc(var(--axm-chroma) * (1 - abs(2 * 0.3072 - 1))) var(--axm-hue)), oklch(0.9536 calc(var(--axm-chroma) * (1 - abs(2 * 0.9536 - 1))) var(--axm-hue)));
  --axm-text-subtle: light-dark(oklch(0.3658 calc(var(--axm-chroma) * (1 - abs(2 * 0.3658 - 1))) var(--axm-hue)), oklch(0.9295 calc(var(--axm-chroma) * (1 - abs(2 * 0.9295 - 1))) var(--axm-hue)));
  --axm-text-subtlest: light-dark(oklch(0.5000 calc(var(--axm-chroma) * (1 - abs(2 * 0.5000 - 1))) var(--axm-hue)), oklch(0.8530 calc(var(--axm-chroma) * (1 - abs(2 * 0.8530 - 1))) var(--axm-hue)));
  --axm-border-decorative: light-dark(oklch(0.5000 calc(var(--axm-chroma) * (1 - abs(2 * 0.5000 - 1))) var(--axm-hue)), oklch(0.5000 calc(var(--axm-chroma) * (1 - abs(2 * 0.5000 - 1))) var(--axm-hue)));
  --axm-border-interactive: light-dark(oklch(0.5000 calc(var(--axm-chroma) * (1 - abs(2 * 0.5000 - 1))) var(--axm-hue)), oklch(0.5846 calc(var(--axm-chroma) * (1 - abs(2 * 0.5846 - 1))) var(--axm-hue)));
  --axm-border-critical: light-dark(oklch(0.4586 calc(var(--axm-chroma) * (1 - abs(2 * 0.4586 - 1))) var(--axm-hue)), oklch(0.8807 calc(var(--axm-chroma) * (1 - abs(2 * 0.8807 - 1))) var(--axm-hue)));
  background: var(--axm-surface);
  transition: background 0.3s ease;
}

