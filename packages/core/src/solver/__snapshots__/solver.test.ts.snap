  --axm-border-critical: light-dark(oklch(0.3112 calc(var(--axm-chroma) * (1 - abs(2 * 0.3112 - 1))) var(--axm-hue)), oklch(0.8684 calc(var(--axm-chroma) * (1 - abs(2 * 0.8684 - 1))) var(--axm-hue)));
  background: var(--axm-surface);
  transition: background 0.3s ease;
  color-scheme: dark;
}

/* Text utilities — consume nearest surface context */
.text-high { color: var(--axm-text-high); }
.text-strong { color: var(--axm-text-strong); }
.text-subtle { color: var(--axm-text-subtle); }
