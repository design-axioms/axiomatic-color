    --axm-text-disabled: GrayText;
    --axm-border-decorative: CanvasText;
    --axm-border-interactive: CanvasText;
    --axm-border-critical: CanvasText;
  }
  .surface-spotlight-action {
    --axm-surface: ButtonFace;
    --axm-text-high: ButtonText;
    --axm-text-strong: ButtonText;
    --axm-text-subtle: ButtonText;
    --axm-text-subtlest: ButtonText;
    --axm-text-link: LinkText;
    --axm-text-disabled: GrayText;
    --axm-border-decorative: CanvasText;
    --axm-border-interactive: ButtonBorder;
    --axm-border-critical: CanvasText;
  }
}"
`;
