  --axm-text-strong: light-dark(oklch(0.2286 calc(var(--axm-chroma) * (1 - abs(2 * 0.2286 - 1))) var(--axm-hue)), oklch(0.9446 calc(var(--axm-chroma) * (1 - abs(2 * 0.9446 - 1))) var(--axm-hue)));
  --axm-text-subtle: light-dark(oklch(0.3191 calc(var(--axm-chroma) * (1 - abs(2 * 0.3191 - 1))) var(--axm-hue)), oklch(0.9204 calc(var(--axm-chroma) * (1 - abs(2 * 0.9204 - 1))) var(--axm-hue)));
  --axm-text-subtlest: light-dark(oklch(0.4658 calc(var(--axm-chroma) * (1 - abs(2 * 0.4658 - 1))) var(--axm-hue)), oklch(0.8437 calc(var(--axm-chroma) * (1 - abs(2 * 0.8437 - 1))) var(--axm-hue)));
  --axm-border-decorative: light-dark(oklch(0.5000 calc(var(--axm-chroma) * (1 - abs(2 * 0.5000 - 1))) var(--axm-hue)), oklch(0.5000 calc(var(--axm-chroma) * (1 - abs(2 * 0.5000 - 1))) var(--axm-hue)));
