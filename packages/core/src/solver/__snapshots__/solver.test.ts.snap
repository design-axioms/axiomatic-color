    --axm-text-high: light-dark(oklch(0.2372 calc(var(--axm-chroma) * (1 - abs(2 * 0.2372 - 1))) var(--axm-hue)), oklch(0.9657 calc(var(--axm-chroma) * (1 - abs(2 * 0.9657 - 1))) var(--axm-hue)));
