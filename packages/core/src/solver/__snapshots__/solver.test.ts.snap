  --axm-border-interactive: light-dark(oklch(0.5000 calc(var(--axm-chroma) * (1 - abs(2 * 0.5000 - 1))) var(--axm-hue)), oklch(0.5914 calc(var(--axm-chroma) * (1 - abs(2 * 0.5914 - 1))) var(--axm-hue)));
  --axm-border-critical: light-dark(oklch(0.1661 calc(var(--axm-chroma) * (1 - abs(2 * 0.1661 - 1))) var(--axm-hue)), oklch(0.8838 calc(var(--axm-chroma) * (1 - abs(2 * 0.8838 - 1))) var(--axm-hue)));
  background: var(--axm-surface);
  transition: background 0.3s ease;
  box-shadow: inset 0 0 0 1px var(--axm-border-decorative, currentColor);
  color-scheme: dark;
}

/* Text utilities — consume nearest surface context */
.text-high { color: var(--axm-text-high); }
.text-strong { color: var(--axm-text-strong); }
.text-subtle { color: var(--axm-text-subtle); }
.text-subtlest { color: var(--axm-text-subtlest); }
.text-link { color: var(--axm-text-link, var(--axm-text-strong)); text-decoration: underline; }
.text-disabled { color: var(--axm-text-disabled, var(--axm-text-subtlest)); }

/* Border utilities — consume nearest surface context */
.border-decorative { border-color: var(--axm-border-decorative); }
.border-interactive { border-color: var(--axm-border-interactive); }
.border-critical { border-color: var(--axm-border-critical); }

/* High contrast — re-solved with tighter targets/scale */
@media (prefers-contrast: more), (prefers-contrast: custom) {
  .surface-page {
    --axm-surface: light-dark(oklch(0.9900 calc(var(--axm-chroma) * (1 - abs(2 * 0.9900 - 1))) var(--axm-hue)), oklch(0.0400 calc(var(--axm-chroma) * (1 - abs(2 * 0.0400 - 1))) var(--axm-hue)));
